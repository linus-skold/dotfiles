[core]
    editor = nvim
    pager = delta
	excludeFile = ~/.gitignore

[gpg]
    format = ssh

[commit]
    gpgsign = true

[interactive]
    diffFilter = delta --color-only

[add.interactive]
    useBuiltin = false

[delta]
    navigate = true
    light = false

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[include]
    path = ~/.dot/git/personal

[includeif "gitdir/i:**/work/**"]
    path = ~/.dot/git/work

[include]
    path = ~/.dot/git/alias

[include]
    path = ~/.dot/git/hooks
